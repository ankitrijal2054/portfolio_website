# ─────────────────────────────────────────────────────────────────────────────
# Chatbot configuration — server-side only.
# Never use the REACT_APP_ prefix here. Anything prefixed REACT_APP_ gets
# bundled into the public JavaScript and would expose your API keys.
# ─────────────────────────────────────────────────────────────────────────────

# LLM provider selector. Switch this + LLM_MODEL to change the chatbot's brain.
# Options: google | anthropic | openai | openrouter
LLM_PROVIDER=google

# Provider-specific model id. Examples:
#   google     → gemini-2.5-flash-lite   (free tier; gemini-2.5-pro is paid since 2026-04-01)
#   anthropic  → claude-haiku-4-5-20251001
#   openai     → gpt-4o-mini
#   openrouter → deepseek/deepseek-chat-v3, moonshotai/kimi-k2, qwen/qwen3-235b
LLM_MODEL=gemini-2.5-flash-lite

# Provider API keys. Only the active provider's key needs a value, but you can
# fill multiple to make switching instant.
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Upstash Redis for per-IP rate limiting.
# Provision via Vercel Marketplace → Upstash; the integration auto-injects these.
KV_REST_API_URL=
KV_REST_API_TOKEN=
